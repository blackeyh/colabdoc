# ---------------------------------------------------------------------------
# ColabDoc environment configuration
# Copy this file to `.env` (or `env`) and fill in values.
# Never commit your filled-in copy.
# ---------------------------------------------------------------------------

# Database --------------------------------------------------------------------
# Zero-config local default. When the backend runs from `backend/`, this creates
# `backend/colabdoc.db`. You can swap this for Postgres later.
DATABASE_URL=sqlite:///./colabdoc.db

# JWT -------------------------------------------------------------------------
# Secret used to sign both access and refresh tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string-for-local-dev
JWT_ALGORITHM=HS256
# Short-lived access token (minutes). Assignment 2 requires 15-30.
JWT_ACCESS_MINUTES=20
# Refresh token lifetime (days).
JWT_REFRESH_DAYS=7

# AI provider -----------------------------------------------------------------
# Which provider to use at runtime: "openai" | "null".
# "null" returns canned responses (safe default for demos and tests; no network).
AI_PROVIDER=null

# OpenAI-compatible endpoint (used when AI_PROVIDER=openai).
# Point at a local LM Studio/Ollama server or at api.openai.com.
LM_STUDIO_BASE_URL=http://127.0.0.1:11434/v1
LM_STUDIO_MODEL=llama3.2

# Optional: use these to hit the real OpenAI API instead of LM Studio.
OPENAI_API_KEY=ollama
OPENAI_MODEL=gpt-4.1-mini
